<%- include('partials/header', { title: pokemon.name + ' | Pokedex' }) %>

<div class="container detail-page">
  <button class="back-link" id="back-btn">&larr; Back to Pokedex</button>
  <script>
    document.getElementById('back-btn').addEventListener('click', function () {
      if (document.referrer && new URL(document.referrer).origin === location.origin) {
        history.back();
      } else {
        location.href = '/';
      }
    });
  </script>

  <div class="detail-header">
    <img src="<%= pokemon.sprite %>" alt="<%= pokemon.name %>" class="detail-image">
    <div class="detail-info">
      <span class="detail-id">#<%= String(pokemon.id).padStart(3, '0') %></span>
      <h1 class="detail-name"><%= pokemon.name %></h1>
      <div class="detail-types">
        <% pokemon.types.forEach(type => { %>
          <span class="type-badge type-<%= type %>"><%= type %></span>
        <% }) %>
      </div>
      <% if (pokemon.flavorText) { %>
        <p class="flavor-text"><%= pokemon.flavorText %></p>
      <% } %>
    </div>
  </div>

  <section class="stats-section">
    <h2>Base Stats</h2>
    <div class="stats">
      <% const statLabels = { 'hp': 'HP', 'attack': 'Attack', 'defense': 'Defense', 'special-attack': 'Sp. Atk', 'special-defense': 'Sp. Def', 'speed': 'Speed' }; %>
      <% const statColors = { 'hp': '#f87171', 'attack': '#f97316', 'defense': '#facc15', 'special-attack': '#60a5fa', 'special-defense': '#a78bfa', 'speed': '#34d399' }; %>
      <% pokemon.stats.forEach(stat => { %>
        <div class="stat-row">
          <span class="stat-label"><%= statLabels[stat.name] || stat.name %></span>
          <span class="stat-value"><%= stat.value %></span>
          <div class="stat-bar-bg">
            <div class="stat-bar" style="width: <%= (stat.value / 255 * 100).toFixed(1) %>%; background: <%= statColors[stat.name] || '#e3350d' %>"></div>
          </div>
        </div>
      <% }) %>
    </div>
  </section>

  <% if (pokemon.moves && pokemon.moves.length) { %>
  <section class="moves-section">
    <h2>Moves</h2>
    <div class="moves-list">
      <% pokemon.moves.forEach(move => { %>
        <div class="move-item">
          <span class="move-name"><%= move.name.replace(/-/g, ' ') %></span>
          <span class="type-badge type-<%= move.type %>"><%= move.type %></span>
          <span class="move-pp"><%= move.pp %>/<%= move.pp %></span>
        </div>
      <% }) %>
    </div>
  </section>
  <% } %>
</div>

<%- include('partials/footer') %>
